{# UVM Coverage Collector Template #}
//==============================================================================
// Coverage: {{ name }}_coverage
// Generated by UVM Testbench Generator
//==============================================================================

class {{ name }}_coverage extends uvm_subscriber #({{ name }}_seq_item);

  `uvm_component_utils({{ name }}_coverage)

  //--------------------------------------------------------------------------
  // Functional coverage group
  //--------------------------------------------------------------------------
  covergroup {{ name }}_cg with function sample({{ name }}_seq_item item);
{% for port in ports %}
{% if port.width > 1 %}
    cp_{{ port.name }}: coverpoint item.{{ port.name }} {
      bins low  = {[{{ port.width }}'d0:{{ port.width }}'d{{ ((2**port.width) // 4) - 1 }}]};
      bins mid  = {[{{ port.width }}'d{{ (2**port.width) // 4 }}:{{ port.width }}'d{{ ((2**port.width) * 3 // 4) - 1 }}]};
      bins high = {[{{ port.width }}'d{{ (2**port.width) * 3 // 4 }}:{{ port.width }}'d{{ (2**port.width) - 1 }}]};
    }
{% else %}
    cp_{{ port.name }}: coverpoint item.{{ port.name }};
{% endif %}
{% endfor %}
  endgroup

{% if protocol_coverage %}
{{ protocol_coverage }}
{% endif %}

  function new(string name = "{{ name }}_coverage", uvm_component parent = null);
    super.new(name, parent);
    {{ name }}_cg = new();
  endfunction

  //--------------------------------------------------------------------------
  // Write - called by analysis port
  //--------------------------------------------------------------------------
  virtual function void write({{ name }}_seq_item t);
    {{ name }}_cg.sample(t);
  endfunction

  //--------------------------------------------------------------------------
  // Report phase
  //--------------------------------------------------------------------------
  virtual function void report_phase(uvm_phase phase);
    `uvm_info(get_type_name(),
      $sformatf("Coverage: %.2f%%", {{ name }}_cg.get_coverage()),
      UVM_LOW)
  endfunction

endclass : {{ name }}_coverage
