{# UVM Sequences Template #}
//==============================================================================
// Sequences for {{ name }}
// Generated by UVM Testbench Generator
//==============================================================================

//------------------------------------------------------------------------------
// Base sequence
//------------------------------------------------------------------------------
class {{ name }}_base_seq extends uvm_sequence #({{ name }}_seq_item);

  `uvm_object_utils({{ name }}_base_seq)

  int unsigned num_items = {{ num_transactions }};

  function new(string name = "{{ name }}_base_seq");
    super.new(name);
  endfunction

  virtual task body();
    `uvm_info(get_type_name(), $sformatf("Starting base sequence with %0d items", num_items), UVM_MEDIUM)
    repeat (num_items) begin
      `uvm_do(req)
    end
  endtask

endclass : {{ name }}_base_seq

//------------------------------------------------------------------------------
// Reset sequence
//------------------------------------------------------------------------------
class {{ name }}_reset_seq extends uvm_sequence #({{ name }}_seq_item);

  `uvm_object_utils({{ name }}_reset_seq)

  function new(string name = "{{ name }}_reset_seq");
    super.new(name);
  endfunction

  virtual task body();
    `uvm_info(get_type_name(), "Starting reset sequence", UVM_MEDIUM)
    `uvm_do_with(req, {
{% for port in ports %}
{% if port.direction.value == 'input' %}
      {{ port.name }} == {{ "'0" if port.width > 1 else "1'b0" }};
{% endif %}
{% endfor %}
    })
  endtask

endclass : {{ name }}_reset_seq

{% for test in tests %}
//------------------------------------------------------------------------------
// {{ test.name }} sequence
//------------------------------------------------------------------------------
class {{ name }}_{{ test.name }}_seq extends {{ name }}_base_seq;

  `uvm_object_utils({{ name }}_{{ test.name }}_seq)

  function new(string name = "{{ name }}_{{ test.name }}_seq");
    super.new(name);
    num_items = {{ test.num_transactions }};
  endfunction

  virtual task body();
    `uvm_info(get_type_name(), "Starting {{ test.name }} sequence", UVM_MEDIUM)
    super.body();
  endtask

endclass : {{ name }}_{{ test.name }}_seq

{% endfor %}
