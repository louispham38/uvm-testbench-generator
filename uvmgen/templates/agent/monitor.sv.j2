{# UVM Monitor Template #}
{# Filter out clk/rst_n — they are infrastructure signals, sampled via monitor_cb only #}
{% set sig_ports = ports|rejectattr("name", "equalto", "clk")|rejectattr("name", "equalto", "rst_n")|list %}
//==============================================================================
// Monitor: {{ name }}_monitor
// Generated by UVM Testbench Generator
//==============================================================================

class {{ name }}_monitor extends uvm_monitor;

  `uvm_component_utils({{ name }}_monitor)

  virtual {{ name }}_if vif;
  uvm_analysis_port #({{ name }}_seq_item) ap;

  function new(string name = "{{ name }}_monitor", uvm_component parent = null);
    super.new(name, parent);
  endfunction

  //--------------------------------------------------------------------------
  // Build phase
  //--------------------------------------------------------------------------
  virtual function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    ap = new("ap", this);
    if (!uvm_config_db#(virtual {{ name }}_if)::get(this, "", "vif", vif))
      `uvm_fatal(get_type_name(), "Failed to get virtual interface")
  endfunction

  //--------------------------------------------------------------------------
  // Run phase
  //--------------------------------------------------------------------------
  virtual task run_phase(uvm_phase phase);
    forever begin
      {{ name }}_seq_item item;
      item = {{ name }}_seq_item::type_id::create("item");
      collect_item(item);
      ap.write(item);
    end
  endtask

  //--------------------------------------------------------------------------
  // Collect a single transaction from the interface
  //--------------------------------------------------------------------------
  virtual task collect_item({{ name }}_seq_item item);
    @(vif.monitor_cb);
{% for port in sig_ports %}
    item.{{ port.name }} = vif.monitor_cb.{{ port.name }};
{% endfor %}
  endtask

endclass : {{ name }}_monitor
