{# UVM Interface Template #}
{# Filter out clk/rst_n since they are declared as interface header ports #}
{% set sig_ports = ports|rejectattr("name", "equalto", "clk")|rejectattr("name", "equalto", "rst_n")|list %}
//==============================================================================
// Interface: {{ name }}_if
// Protocol:  {{ protocol_name }}
// Generated by UVM Testbench Generator
//==============================================================================

interface {{ name }}_if (input logic clk, input logic rst_n);

{% for port in sig_ports %}
{% if port.direction.value == 'inout' %}
  wire {% if port.width > 1 %}[{{ port.width - 1 }}:0] {% endif %}{{ port.name }};
{% else %}
  {{ port.signal_type.value }} {% if port.width > 1 %}[{{ port.width - 1 }}:0] {% endif %}{{ port.name }};
{% endif %}
{% endfor %}

  //--------------------------------------------------------------------------
  // Clocking blocks
  //--------------------------------------------------------------------------
  clocking driver_cb @(posedge clk);
    default input #1 output #1;
{% for port in sig_ports %}
{% if port.direction.value == 'input' %}
    output {{ port.name }};
{% elif port.direction.value == 'output' %}
    input  {{ port.name }};
{% else %}
    inout  {{ port.name }};
{% endif %}
{% endfor %}
  endclocking

  clocking monitor_cb @(posedge clk);
    default input #1;
{% for port in sig_ports %}
    input {{ port.name }};
{% endfor %}
  endclocking

  //--------------------------------------------------------------------------
  // Modports
  //--------------------------------------------------------------------------
  modport DRV  (clocking driver_cb,  input clk, input rst_n);
  modport MON  (clocking monitor_cb, input clk, input rst_n);
  modport DUT  (
    input  clk,
    input  rst_n{{ "," if sig_ports|length > 0 else "" }}
{% for port in sig_ports %}
{% if port.direction.value == 'input' %}
    input  {{ port.name }}{{ "," if not loop.last else "" }}
{% elif port.direction.value == 'output' %}
    output {{ port.name }}{{ "," if not loop.last else "" }}
{% else %}
    inout  {{ port.name }}{{ "," if not loop.last else "" }}
{% endif %}
{% endfor %}
  );

  //--------------------------------------------------------------------------
  // Assertions (protocol checks)
  //--------------------------------------------------------------------------
{% if protocol_assertions %}
{{ protocol_assertions }}
{% else %}
  // Add custom protocol assertions here
  // Example:
  // property p_valid_ready;
  //   @(posedge clk) disable iff (!rst_n)
  //     valid |-> ##[0:16] ready;
  // endproperty
  // assert property (p_valid_ready) else $error("Valid-Ready timeout");
{% endif %}

endinterface : {{ name }}_if
